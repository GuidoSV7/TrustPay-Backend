# TrustPay backend — copia a .env

# PostgreSQL (o Neon: DATABASE_HOST, DATABASE_PORT, DATABASE_USER, DATABASE_PASS, DATABASE_NAME)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASS=postgres
DATABASE_NAME=trustpay

# SSL para host remoto (Neon/Railway): ya se usa por defecto si host ≠ localhost
# DATABASE_SSL=true

PORT=3001

# Base URL de la API (para links Solana Pay Transaction Request).
# Producción: https://api.trustpay.com
# Local + Phantom: usa ngrok (ngrok http 3001) y pon aquí https://xxx.ngrok-free.app
# Ver docs/PHANTOM_QR_TROUBLESHOOTING.md si Phantom no deja pagar al escanear.
API_BASE_URL=https://hypertragically-calced-kattie.ngrok-free.dev
# Orígenes permitidos (coma). Para Phantom+ngrok en dev: añade tu URL ngrok o usa *
CORS_ORIGIN=http://localhost:3000,http://localhost:5173,https://hypertragically-calced-kattie.ngrok-free.dev

JWT_SECRET=cambia-esto-en-produccion
JWT_EXPIRES_IN=1d

# Sincronizar esquema TypeORM al arrancar (dev: true). Producción: false + migraciones
TYPEORM_SYNCHRONIZE=true

# Opcional: API interna
CLIENT_SECRET=

# ── Solana / Blockchain ───────────────────────────────────────────────────────
# RPC de Solana (devnet para desarrollo, mainnet-beta para producción)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Program ID del contrato TrustPay desplegado
SOLANA_PROGRAM_ID=6R5q6P5975rhYg2KXaGLPjysYBtMHGwqBajmYDJLwVih

# Keypair del backend TrustPay (authority que paga y firma las transacciones)
# Formato: array JSON del secret key — obtenido con: solana-keygen new --outfile authority.json
# En Solana Playground: Settings > Wallet > Export Private Key
TRUSTPAY_KEYPAIR=[1,2,3,...]

# Opcional: wallet que recibe la comisión (transfer aparte del escrow). Si se omite, se usa la pubkey de TRUSTPAY_KEYPAIR.
# PLATFORM_FEE_WALLET=

# Sondeo de pagos Solana Pay (cron cada 30s). Desactivar: false
PAYMENT_POLL_ENABLED=true
